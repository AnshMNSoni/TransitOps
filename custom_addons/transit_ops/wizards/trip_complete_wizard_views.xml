<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="trip_complete_wizard_view_form" model="ir.ui.view">
        <field name="name">transit.trip.complete.wizard.form</field>
        <field name="model">transit.trip.complete.wizard</field>
        <field name="arch" type="xml">
            <form string="Complete Trip">
                <group>
                    <group>
                        <field name="trip_id" readonly="1"/>
                    </group>
                </group>
                <group>
                    <group string="Trip Details">
                        <field name="final_odometer"/>
                        <field name="actual_distance"/>
                        <field name="fuel_consumed"/>
                        <field name="fuel_price_per_liter"/>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm" string="Complete Trip" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_trip_complete_wizard" model="ir.actions.act_window">
        <field name="name">Complete Trip</field>
        <field name="res_model">transit.trip.complete.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'active_id': active_id}</field>
    </record>
</odoo>
