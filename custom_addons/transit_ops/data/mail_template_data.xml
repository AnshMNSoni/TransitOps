<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="mail_template_license_expiry" model="mail.template">
            <field name="name">TransitOps: License Expiry Warning</field>
            <field name="model_id" ref="model_transit_driver"/>
            <field name="subject">TransitOps — Driver Licenses Expiring Soon</field>
            <field name="email_from">{{ (object.company_id.email or user.email or '') }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; max-width: 600px; margin: auto;
                            padding: 20px; background: #f9f9f9; border: 1px solid #ddd;
                            border-radius: 8px;">
                    <h2 style="color: #d9534f; border-bottom: 2px solid #d9534f; padding-bottom: 8px;">
                        ⚠ License Expiry Alert
                    </h2>
                    <p>Hello <t t-esc="ctx.get('recipient_name', 'Safety Officer')"/>,</p>
                    <p>The following drivers have licenses expiring within the next 30 days:</p>
                    <table style="width:100%; border-collapse: collapse; margin-top: 15px;">
                        <thead>
                            <tr style="background: #337ab7; color: white;">
                                <th style="padding: 10px; text-align: left;">Driver</th>
                                <th style="padding: 10px; text-align: left;">License #</th>
                                <th style="padding: 10px; text-align: left;">Expiry Date</th>
                                <th style="padding: 10px; text-align: left;">Contact</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="ctx.get('expiring_drivers', [])" t-as="d">
                                <tr style="border-bottom: 1px solid #eee;">
                                    <td style="padding: 10px;"><t t-esc="d.name"/></td>
                                    <td style="padding: 10px;"><t t-esc="d.license_number"/></td>
                                    <td style="padding: 10px; color: #d9534f; font-weight: bold;">
                                        <t t-esc="d.license_expiry"/>
                                    </td>
                                    <td style="padding: 10px;">
                                        <t t-esc="d.contact_number or 'N/A'"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <p style="margin-top: 20px;">
                        Please review these records and initiate the renewal process.
                    </p>
                    <p style="color: #888; font-size: 12px; margin-top: 30px;">
                        — TransitOps Automated Notification
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>
