<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_transit_vehicle" model="ir.actions.report">
        <field name="name">Vehicle Operations Report</field>
        <field name="model">transit.vehicle</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">transit_ops.report_transit_vehicle_document</field>
        <field name="report_file">transit_ops.report_transit_vehicle_document</field>
        <field name="binding_model_id" ref="model_transit_vehicle"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_transit_vehicle_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Vehicle Operations — <span t-field="doc.name"/></h2>
                        <div class="row mt32">
                            <div class="col-6">
                                <strong>Registration:</strong> <span t-field="doc.registration_number"/><br/>
                                <strong>Type:</strong> <span t-field="doc.vehicle_type"/><br/>
                                <strong>Region:</strong> <span t-field="doc.region"/><br/>
                                <strong>Status:</strong> <span t-field="doc.status"/>
                            </div>
                            <div class="col-6">
                                <strong>Max Load (kg):</strong> <span t-field="doc.max_load_capacity"/><br/>
                                <strong>Odometer (km):</strong> <span t-field="doc.odometer"/><br/>
                                <strong>Acquisition Cost:</strong> <span t-field="doc.acquisition_cost"/>
                            </div>
                        </div>

                        <h3 class="mt32">Financial Performance</h3>
                        <table class="table table-sm">
                            <tbody>
                                <tr>
                                    <td>Total Fuel Cost</td>
                                    <td class="text-end"><span t-field="doc.total_fuel_cost"/></td>
                                </tr>
                                <tr>
                                    <td>Total Maintenance Cost</td>
                                    <td class="text-end"><span t-field="doc.total_maintenance_cost"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Total Operational Cost</strong></td>
                                    <td class="text-end"><strong><span t-field="doc.total_operational_cost"/></strong></td>
                                </tr>
                                <tr>
                                    <td>Total Revenue</td>
                                    <td class="text-end"><span t-field="doc.total_revenue"/></td>
                                </tr>
                                <tr class="table-info">
                                    <td><strong>Vehicle ROI (%)</strong></td>
                                    <td class="text-end"><strong><span t-field="doc.vehicle_roi"/></strong></td>
                                </tr>
                                <tr>
                                    <td>Fuel Efficiency (km/L)</td>
                                    <td class="text-end"><span t-field="doc.fuel_efficiency"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
