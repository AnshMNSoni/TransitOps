<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ========== Module Category ========== -->
        <record id="module_category_transit_ops" model="ir.module.category">
            <field name="name">TransitOps</field>
            <field name="description">Access rights for TransitOps roles.</field>
            <field name="sequence">20</field>
        </record>

        <!-- ========== Privileges ========== -->
        <record id="privilege_transit_fleet_manager" model="res.groups.privilege">
            <field name="name">Fleet Manager</field>
            <field name="category_id" ref="module_category_transit_ops"/>
        </record>

        <record id="privilege_transit_dispatcher" model="res.groups.privilege">
            <field name="name">Driver / Dispatcher</field>
            <field name="category_id" ref="module_category_transit_ops"/>
        </record>

        <record id="privilege_transit_safety_officer" model="res.groups.privilege">
            <field name="name">Safety Officer</field>
            <field name="category_id" ref="module_category_transit_ops"/>
        </record>

        <record id="privilege_transit_financial_analyst" model="res.groups.privilege">
            <field name="name">Financial Analyst</field>
            <field name="category_id" ref="module_category_transit_ops"/>
        </record>

        <!-- ========== Groups ========== -->
        <record id="group_transit_fleet_manager" model="res.groups">
            <field name="name">Fleet Manager</field>
            <field name="privilege_id" ref="privilege_transit_fleet_manager"/>
            <field name="comment">Full access to vehicles, maintenance, and analytics.</field>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_transit_dispatcher" model="res.groups">
            <field name="name">Driver / Dispatcher</field>
            <field name="privilege_id" ref="privilege_transit_dispatcher"/>
            <field name="comment">Write access to trips; view vehicles and drivers.</field>
        </record>

        <record id="group_transit_safety_officer" model="res.groups">
            <field name="name">Safety Officer</field>
            <field name="privilege_id" ref="privilege_transit_safety_officer"/>
            <field name="comment">Full access to drivers; view-only on trips.</field>
        </record>

        <record id="group_transit_financial_analyst" model="res.groups">
            <field name="name">Financial Analyst</field>
            <field name="privilege_id" ref="privilege_transit_financial_analyst"/>
            <field name="comment">View vehicles; write access to expenses and fuel logs.</field>
        </record>

    </data>
</odoo>
