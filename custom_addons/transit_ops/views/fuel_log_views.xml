<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ LIST VIEW ============ -->
    <record id="transit_fuel_log_view_list" model="ir.ui.view">
        <field name="name">transit.fuel.log.list</field>
        <field name="model">transit.fuel.log</field>
        <field name="arch" type="xml">
            <list string="Fuel Logs" sample="1">
                <field name="name"/>
                <field name="date"/>
                <field name="vehicle_id"/>
                <field name="trip_id"/>
                <field name="liters" sum="Total Liters"/>
                <field name="cost_per_liter"/>
                <field name="total_cost" sum="Total Cost"/>
            </list>
        </field>
    </record>

    <!-- ============ FORM VIEW ============ -->
    <record id="transit_fuel_log_view_form" model="ir.ui.view">
        <field name="name">transit.fuel.log.form</field>
        <field name="model">transit.fuel.log</field>
        <field name="arch" type="xml">
            <form string="Fuel Log">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Info">
                            <field name="vehicle_id" options="{'no_create': True}"/>
                            <field name="trip_id" options="{'no_create': True}"/>
                            <field name="date"/>
                        </group>
                        <group string="Fuel Details">
                            <field name="liters"/>
                            <field name="cost_per_liter"/>
                            <field name="total_cost" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============ SEARCH VIEW ============ -->
    <record id="transit_fuel_log_view_search" model="ir.ui.view">
        <field name="name">transit.fuel.log.search</field>
        <field name="model">transit.fuel.log</field>
        <field name="arch" type="xml">
            <search string="Fuel Logs">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="trip_id"/>
                <filter string="This Month" name="this_month"
                        domain="[('date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter string="Vehicle" name="group_vehicle"
                            context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Date" name="group_date"
                            context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============ ACTION ============ -->
    <record id="action_transit_fuel_log" model="ir.actions.act_window">
        <field name="name">Fuel Logs</field>
        <field name="res_model">transit.fuel.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="transit_fuel_log_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Log your first fuel entry
            </p>
            <p>Track fuel consumption and costs per vehicle and trip.</p>
        </field>
    </record>

</odoo>
