<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ VEHICLE STATUS GRAPH ============ -->
    <record id="view_transit_vehicle_graph_status" model="ir.ui.view">
        <field name="name">transit.vehicle.graph.status</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <graph string="Vehicle Status Distribution" type="pie">
                <field name="status"/>
            </graph>
        </field>
    </record>

    <!-- ============ DASHBOARD FORM VIEW ============ -->
    <record id="view_transit_dashboard_form" model="ir.ui.view">
        <field name="name">transit.dashboard.form</field>
        <field name="model">transit.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard" create="0" edit="0" delete="0">
                <sheet>
                    <!-- Header Title -->
                    <div class="text-center my-3">
                        <h1 class="display-5 fw-bold text-primary">TransitOps Fleet Dashboard</h1>
                        <p class="text-muted">Real-time KPIs and fleet operations summary</p>
                    </div>

                    <!-- Row 1: Key Metrics -->
                    <div class="row g-4 mb-4">
                        <!-- Fleet Utilization Card (Large) -->
                        <div class="col-12 col-md-4" groups="transit_ops.group_transit_fleet_manager,transit_ops.group_transit_dispatcher,transit_ops.group_transit_financial_analyst">
                            <div class="card border-0 shadow-sm text-center bg-primary text-white h-100" style="border-radius: 12px;">
                                <div class="card-body d-flex flex-column justify-content-center p-4">
                                    <h5 class="text-white-50 text-uppercase fw-semibold mb-2">Fleet Utilization</h5>
                                    <div class="my-2">
                                        <span class="display-3 fw-bold"><field name="fleet_utilization"/></span>
                                        <span class="display-6 fw-bold">%</span>
                                    </div>
                                    <p class="small mb-0 text-white-50">Active vehicles vs total active fleet capacity</p>
                                </div>
                            </div>
                        </div>

                        <!-- Vehicles Summary Card -->
                        <div class="col-12 col-sm-6 col-md-4" groups="transit_ops.group_transit_fleet_manager,transit_ops.group_transit_dispatcher,transit_ops.group_transit_financial_analyst">
                            <div class="card border-0 shadow-sm h-100 bg-light" style="border-radius: 12px;">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 class="text-muted text-uppercase fw-semibold mb-0">Vehicle Fleet</h5>
                                        <span class="badge bg-secondary rounded-pill"><field name="total_vehicles"/> Total</span>
                                    </div>
                                    <div class="list-group list-group-flush bg-transparent">
                                        <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0 py-2 border-bottom">
                                            <span class="text-success"><i class="fa fa-check-circle me-2"/>Available</span>
                                            <span class="fw-bold fs-5 text-success"><field name="available_vehicles"/></span>
                                        </div>
                                        <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0 py-2 border-bottom">
                                            <span class="text-warning"><i class="fa fa-truck me-2"/>On Trip</span>
                                            <span class="fw-bold fs-5 text-warning"><field name="ontrip_vehicles"/></span>
                                        </div>
                                        <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0 py-2 border-0">
                                            <span class="text-danger"><i class="fa fa-wrench me-2"/>In Shop (Maintenance)</span>
                                            <span class="fw-bold fs-5 text-danger"><field name="maintenance_vehicles"/></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Operations Summary Card -->
                        <div class="col-12 col-sm-6 col-md-4" groups="transit_ops.group_transit_dispatcher,transit_ops.group_transit_safety_officer">
                            <div class="card border-0 shadow-sm h-100 bg-light" style="border-radius: 12px;">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 class="text-muted text-uppercase fw-semibold mb-0">Operations</h5>
                                        <span class="badge bg-secondary rounded-pill"><field name="total_drivers"/> Drivers</span>
                                    </div>
                                    <div class="list-group list-group-flush bg-transparent">
                                        <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0 py-2 border-bottom">
                                            <span class="text-warning"><i class="fa fa-road me-2"/>Active Trips</span>
                                            <span class="fw-bold fs-5 text-warning"><field name="active_trips"/></span>
                                        </div>
                                        <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0 py-2 border-bottom">
                                            <span class="text-muted"><i class="fa fa-clock-o me-2"/>Pending Trips</span>
                                            <span class="fw-bold fs-5 text-dark"><field name="pending_trips"/></span>
                                        </div>
                                        <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0 py-2 border-0">
                                            <span class="text-success"><i class="fa fa-user me-2"/>Drivers On Duty</span>
                                            <span class="fw-bold fs-5 text-success"><field name="drivers_on_duty"/></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============ DASHBOARD ACTION (SERVER ACTION) ============ -->
    <record id="action_transit_dashboard_server" model="ir.actions.server">
        <field name="name">Dashboard</field>
        <field name="model_id" ref="model_transit_dashboard"/>
        <field name="state">code</field>
        <field name="code">
            action = model.get_dashboard_action()
        </field>
    </record>

    <!-- ============ QUICK-ACCESS ACTIONS FOR DASHBOARD KPI CARDS ============ -->
    <record id="action_dashboard_available_vehicles" model="ir.actions.act_window">
        <field name="name">Available Vehicles</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status', '=', 'available')]</field>
    </record>

    <record id="action_dashboard_on_trip_vehicles" model="ir.actions.act_window">
        <field name="name">Vehicles On Trip</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status', '=', 'on_trip')]</field>
    </record>

    <record id="action_dashboard_in_shop_vehicles" model="ir.actions.act_window">
        <field name="name">Vehicles In Shop</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status', '=', 'in_shop')]</field>
    </record>

    <record id="action_dashboard_active_trips" model="ir.actions.act_window">
        <field name="name">Active Trips</field>
        <field name="res_model">transit.trip</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'dispatched')]</field>
    </record>

    <record id="action_dashboard_pending_trips" model="ir.actions.act_window">
        <field name="name">Pending Trips</field>
        <field name="res_model">transit.trip</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'draft')]</field>
    </record>

    <record id="action_dashboard_drivers_on_duty" model="ir.actions.act_window">
        <field name="name">Drivers On Duty</field>
        <field name="res_model">transit.driver</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status', '=', 'on_trip')]</field>
    </record>

</odoo>
