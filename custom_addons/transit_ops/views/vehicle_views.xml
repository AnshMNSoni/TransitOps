<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ VEHICLE TREE VIEW ============ -->
    <record id="transit_vehicle_view_tree" model="ir.ui.view">
        <field name="name">transit.vehicle.tree</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles"
                  decoration-success="status == 'available'"
                  decoration-warning="status == 'on_trip'"
                  decoration-info="status == 'in_shop'"
                  decoration-muted="status == 'retired'">
                <field name="name"/>
                <field name="registration_number"/>
                <field name="vehicle_type"/>
                <field name="region"/>
                <field name="max_load_capacity" sum="Total Capacity"/>
                <field name="odometer"/>
                <field name="acquisition_cost" widget="monetary"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'available'"
                       decoration-warning="status == 'on_trip'"
                       decoration-info="status == 'in_shop'"
                       decoration-muted="status == 'retired'"/>
            </list>
        </field>
    </record>

    <!-- ============ VEHICLE FORM VIEW ============ -->
    <record id="transit_vehicle_view_form" model="ir.ui.view">
        <field name="name">transit.vehicle.form</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Vehicle Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="registration_number"/>
                            <field name="vehicle_type"/>
                            <field name="region"/>
                            <field name="status" widget="badge"
                                   decoration-success="status == 'available'"
                                   decoration-warning="status == 'on_trip'"
                                   decoration-info="status == 'in_shop'"
                                   decoration-muted="status == 'retired'"/>
                        </group>
                        <group>
                            <field name="max_load_capacity"/>
                            <field name="odometer"/>
                            <field name="acquisition_cost"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Performance" name="performance">
                            <group>
                                <group string="Revenue &amp; Costs">
                                    <field name="total_revenue"/>
                                    <field name="total_fuel_cost"/>
                                    <field name="total_maintenance_cost"/>
                                    <field name="total_operational_cost"/>
                                </group>
                                <group string="Efficiency">
                                    <field name="vehicle_roi" widget="progressbar"/>
                                    <field name="fuel_efficiency"/>
                                </group>
                            </group>
                        </page>
                        <page string="Trips" name="trips">
                            <field name="trip_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ============ VEHICLE SEARCH VIEW ============ -->
    <record id="transit_vehicle_view_search" model="ir.ui.view">
        <field name="name">transit.vehicle.search</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <search string="Search Vehicles">
                <field name="name"/>
                <field name="registration_number"/>
                <field name="region"/>
                <filter string="Available" name="available" domain="[('status','=','available')]"/>
                <filter string="On Trip" name="on_trip" domain="[('status','=','on_trip')]"/>
                <filter string="In Shop" name="in_shop" domain="[('status','=','in_shop')]"/>
                <group name="group_by">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Vehicle Type" name="group_type" context="{'group_by': 'vehicle_type'}"/>
                    <filter string="Region" name="group_region" context="{'group_by': 'region'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============ VEHICLE ACTION ============ -->
    <record id="action_transit_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="transit_vehicle_view_search"/>
        <field name="context">{'search_default_available': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No vehicles registered yet!
            </p>
            <p>Create your first vehicle to get started with fleet management.</p>
        </field>
    </record>

</odoo>
