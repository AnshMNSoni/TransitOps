<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ LIST VIEW ============ -->
    <record id="transit_expense_view_list" model="ir.ui.view">
        <field name="name">transit.expense.list</field>
        <field name="model">transit.expense</field>
        <field name="arch" type="xml">
            <list string="Expenses" sample="1">
                <field name="name"/>
                <field name="date"/>
                <field name="vehicle_id"/>
                <field name="trip_id"/>
                <field name="toll" sum="Total Toll"/>
                <field name="other" sum="Total Other"/>
                <field name="maintenance_linked" sum="Maintenance"/>
                <field name="total" sum="Grand Total"/>
            </list>
        </field>
    </record>

    <!-- ============ FORM VIEW ============ -->
    <record id="transit_expense_view_form" model="ir.ui.view">
        <field name="name">transit.expense.form</field>
        <field name="model">transit.expense</field>
        <field name="arch" type="xml">
            <form string="Expense">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Highway toll return trip"/></h1>
                    </div>
                    <group>
                        <group string="Info">
                            <field name="vehicle_id" options="{'no_create': True}"/>
                            <field name="trip_id" options="{'no_create': True}"/>
                            <field name="date"/>
                        </group>
                        <group string="Amounts">
                            <field name="toll"/>
                            <field name="other"/>
                            <field name="maintenance_linked" readonly="1"/>
                            <field name="total" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============ SEARCH VIEW ============ -->
    <record id="transit_expense_view_search" model="ir.ui.view">
        <field name="name">transit.expense.search</field>
        <field name="model">transit.expense</field>
        <field name="arch" type="xml">
            <search string="Expenses">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="trip_id"/>
                <group expand="0" string="Group By">
                    <filter string="Vehicle" name="group_vehicle"
                            context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Trip" name="group_trip"
                            context="{'group_by': 'trip_id'}"/>
                    <filter string="Date" name="group_date"
                            context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============ ACTION ============ -->
    <record id="action_transit_expense" model="ir.actions.act_window">
        <field name="name">Other Expenses</field>
        <field name="res_model">transit.expense</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="transit_expense_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Log your first expense
            </p>
            <p>Track tolls, misc costs, and linked maintenance expenses.</p>
        </field>
    </record>

</odoo>
