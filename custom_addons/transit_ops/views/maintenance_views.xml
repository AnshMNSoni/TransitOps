<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ LIST VIEW ============ -->
    <record id="transit_maintenance_view_list" model="ir.ui.view">
        <field name="name">transit.maintenance.list</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <list string="Maintenance Records" sample="1"
                  decoration-warning="state == 'active'"
                  decoration-success="state == 'completed'">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <field name="date"/>
                <field name="cost" sum="Total Cost"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'active'"
                       decoration-success="state == 'completed'"/>
            </list>
        </field>
    </record>

    <!-- ============ FORM VIEW ============ -->
    <record id="transit_maintenance_view_form" model="ir.ui.view">
        <field name="name">transit.maintenance.form</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance Record">
                <header>
                    <button name="action_complete"
                            string="Mark Completed"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'active'"/>
                    <button name="action_reset_to_active"
                            string="Reset to Active"
                            type="object"
                            invisible="state != 'completed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Service Info">
                            <field name="vehicle_id" options="{'no_create': True}"/>
                            <field name="service_type"/>
                            <field name="date"/>
                        </group>
                        <group string="Cost">
                            <field name="cost" widget="monetary"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"
                               placeholder="Details of the service performed..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============ SEARCH VIEW ============ -->
    <record id="transit_maintenance_view_search" model="ir.ui.view">
        <field name="name">transit.maintenance.search</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <search string="Maintenance">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <filter string="Active" name="active"
                        domain="[('state', '=', 'active')]"/>
                <filter string="Completed" name="completed"
                        domain="[('state', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Vehicle" name="group_vehicle"
                            context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Service Type" name="group_type"
                            context="{'group_by': 'service_type'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============ ACTION ============ -->
    <record id="action_transit_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">transit.maintenance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="transit_maintenance_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Log your first maintenance record
            </p>
            <p>Track servicing and repairs for your fleet.</p>
        </field>
    </record>

</odoo>
